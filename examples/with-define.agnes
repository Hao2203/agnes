;; Declare a compound tool. Its body is type-checked against its signature,
;; but the MVP runtime does not yet inline defines, so we execute the
;; equivalent inline pipeline below.
(define read-and-translate
  :params  [(path: Path) (target: String)]
  :provides PlainText
  (pipe
    (tool read-file :path path)
    (tool translate :lang target)))

(pipe
  (tool read-file :path "README.md")
  (tool translate :lang "ja"))
