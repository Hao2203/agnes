;; Parallel branches (Task 9 runtime executes them sequentially, but the
;; DAG shape is genuine fan-out). Each branch is a self-contained pipe
;; because MVP `par` does not propagate `let` bindings to later pipe
;; steps.
(par
  (pipe
    (tool read-file "README.md")
    (tool summarize))
  (tool translate (tool read-file "README.md") "ja"))
